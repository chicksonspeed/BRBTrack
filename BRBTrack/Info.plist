<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Hide the Dock icon; app lives entirely in the menu bar. -->
	<key>LSUIElement</key>
	<true/>

	<key>CFBundleName</key>
	<string>BRBTrack</string>

	<key>CFBundleDisplayName</key>
	<string>BRB//TRACK</string>

	<key>CFBundleIdentifier</key>
	<string>com.brbtrack.BRBTrack</string>

	<key>CFBundleVersion</key>
	<string>1</string>

	<key>CFBundleShortVersionString</key>
	<string>1.0</string>

	<key>CFBundlePackageType</key>
	<string>APPL</string>

	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>

	<key>CFBundleDevelopmentRegion</key>
	<string>en</string>

	<key>NSHumanReadableCopyright</key>
	<string>BRBTrack — offline utility</string>

	<key>NSPrincipalClass</key>
	<string>NSApplication</string>

	<!-- Required for drag-and-drop of local files into the popover. -->
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsLocalNetworking</key>
		<true/>
	</dict>
</dict>
</plist>
